{
  "driver": "Playwright",
  "browser": "chrome",
  "host": "https://www.github.com/",
  "scenarios": [
    {
      "name": "Signup Test",
      "steps": [
        {
          "description": "Navigate to create account",
          "actions": [
            {
              "action": "click",
              "locator": { "by": "role", "role": "link", "name": "Sign in" }
            },
            {
              "action": "click",
              "locator": { "by": "role", "role": "link", "name": "Create an account" },
              "label": "Click on Create an Account"
            }
          ]
        },
        {
          "description": "Fill the signup form",
          "actions": [
            {
              "action": "fill",
              "locator": { "by": "role", "role": "textbox", "name": "Email" },
              "value": "playwright-json-runner@automategpt.com"
            },
            {
              "action": "fill",
              "locator": { "by": "role", "role": "textbox", "name": "Password" },
              "value": "Some Password"
            },
            {
              "action": "fill",
              "locator": { "by": "role", "role": "textbox", "name": "Username" },
              "value": "miguel_acosta"
            },
            {
              "action": "click",
              "locator": { "by": "role", "role": "button", "name": "Create account" }
            }
          ]
        },
        {
          "description": "Assertions",
          "actions": [
            {
              "action": "assertValue",
              "locator": { "by": "role", "role": "textbox", "name": "Email" },
              "value": "playwright-json-runner@automategpt.com"
            },
            {
              "action": "sleep",
              "duration": 2000
            },
            {
              "action": "sleep",
              "duration": 8000
            }
          ]
        }
      ]
    }
  ]
}
